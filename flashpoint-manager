check_install_fun() { # Function for checking if Flashpoint is installed.
    local oneYn

    # If the state isn't "install" then do a quick check.
    if [ "$STATE" != "install" ]; then

        # If no Flashpoint installation was detected then tell the user and exit.
        if ! grep -q "Flashpoint" "$HOME/.flashpoint/fp-dt/version.txt" 2>/dev/null; then
            printf "Flashpoint isn't installed!\n"
            exit 1
        fi

    else

        # If "$HOME/.flashpoint" exists the continue.
        if [ -d "$HOME/.flashpoint" ]; then

            # Check if Flashpoint is installed.
            if grep -q "Flashpoint" "$HOME/.flashpoint/fp-dt/version.txt" 2>/dev/null; then
                printf "Flashpoint is already installed!\n"
                exit 2
        
            else
                # If Flashpoint wasn't installed but "$HOME/.flashpoint" existed then ask the user if they want to delete the directory.
                printf "'$HOME/.flashpoint' already exists, but no Flashpoint installation was detected! Would you like to delete everything in this directory?\nThis is asked because '$HOME/.flashpoint' might contain important data.\n"
                read -rp "[Y/n] " oneYn

                # If user says yes then delete and remake the directory.
                if [[ "$oneYn" =~ ^([Yy]|[Yy][Ee][Ss])$ ]]; then
                     rm -rf "$HOME/.flashpoint"
                     mkdir -p "$HOME/.flashpoint/fp-dt"

                # If user says no then exit.
                elif [[ "$oneYn" =~ ^([Nn]|[Nn][Oo])$ ]]; then
                    printf "A fresh '$HOME/.flashpoint' is needed for installing Flashpoint, exiting..\n"
                    exit 1

                # Exit if yes or no weren't said.
                else
                    printf "Unknown option, exiting..\n"
                    exit 2
                fi    

            fi    

        # If "$HOME/.flashpoint" doesn't exist then make the directory and finish.
        else
            mkdir -p "$HOME/.flashpoint/fp-dt"
        fi

    fi    
}

help_list_fun() { # Help list.
    cat <<EOF
Usage:
--help                 |  Brings up the manager options.
--install-flashpoint   |  Installs Flashpoint and the Distrobox container.
--update-flashpoint    |  Updates Flashpoint.
--reinstall-flashpoint |  Re-installs Flashpoint and the Distrobox container.
--delete-flashpoint    |  Deletes Flashpoint the Distrobox container.
--enable-wine-wayland  |  Enables Wine native Wayland. (Disabled by default)
--disable-wine-wayland |  Disables Wine native Wayland. (Disabled by default)
--enable-audio-fix     |  Enables ALSA audio backend for Wine this can fix issue with audio. (Disabled by default)
--disable-audio-fix    |  Disables the ALSA audio backend in favor of PulseAudio. (Disabled by default)
EOF
    exit 0
}

##### entry point #####

    # Lock file to ensure only one instance of the script can run.
    if [ -e "/tmp/flashpoint-manager.lock" ]; then
        printf "Another instance of the Flashpoint manager is already running.\nPlease wait until it finishes.\n"
        exit 1
    fi
    
    trap 'rm -f "/tmp/flashpoint-manager.lock"' EXIT

    touch "/tmp/flashpoint-manager.lock"

    if [ -z "$1" ]; then
		help_list_fun
		exit 2
	fi

	case "$1" in
		--help)							if [ $# -ne 1 ]; then
										    printf "Error: --help does not accept extra arguments.\n"
											exit 2
										fi
										help_list_fun
										;;
			
    	--install-flashpoint)			if [ $# -ne 1 ]; then
            								printf "Error: --install-flashpoint does not accept extra arguments.\n"
            								exit 2
            							fi
                                        STATE="install"
                                        check_dependencies_fun
                                        check_install_fun
            							distrobox_setup_fun 
            							;;

    	--update-flashpoint) 			if [ $# -ne 1 ]; then
            								printf "Error: --update-flashpoint does not accept extra arguments.\n"
            								exit 2
            							fi
                                        check_dependencies_fun
                                        check_install_fun
            							update_fp_fun
                                        ;;
    
    	--reinstall-flashpoint)			if [ $# -ne 1 ]; then
											printf "Error: --reinstall-flashpoint does not accept extra arguments.\n"
											exit 2
										fi
										STATE="reinstall"
                                        check_dependencies_fun
                                        check_install_fun
										delete_fun
										;;

    	--delete-flashpoint) 			if [ $# -ne 1 ]; then # check_dependencies_fun doesn't need to be called since we are already deleting.
            								printf "Error: --delete-flashpoint does not accept extra arguments.\n"
            								exit 2
            							fi
            							STATE="delete"
                                        check_install_fun
            							delete_fun
										;;

    	--enable-wine-wayland) 			if [ $# -ne 1 ]; then
            								printf "Error: --enable-wine-wayland does not accept extra arguments.\n"
            								exit 2
            							fi
            							STATE="wn_wy_en"
                                        check_dependencies_fun
                                        check_install_fun
            							win_wy_fun
            							;;

    	--disable-wine-wayland) 		if [ $# -ne 1 ]; then
            								printf "Error: --disable-wine-wayland does not accept extra arguments.\n"
            								exit 2
            							fi
            							STATE="wn_wy_di"
                                        check_dependencies_fun
                                        check_install_fun
            							win_wy_fun
            							;;

    	--enable-audio-fix) 			if [ $# -ne 1 ]; then
            								printf "Error: --enable-audio-fix does not accept extra arguments.\n"
            								exit 2
            							fi
            							STATE="ad_fx_en"
                                        check_dependencies_fun
            							ad_fx_fun
            							;;

    	--disable-audio-fix) 			if [ $# -ne 1 ]; then
            								printf "Error: --disable-audio-fix does not accept extra arguments.\n"
            								exit 2
            							fi
            							STATE="ad_fx_di"
                                        check_dependencies_fun
                                        check_install_fun
            							ad_fx_fun
            							;;

    	*)								printf "Unknown Command: \"$1\"\n"
    									help_list_fun
    									exit 2 
    									;;
	esac
