check_dependencies_fun() { # Function for checking dependencies.
    if ! command -v distrobox > /dev/null 2>&1; then
        printf "An installation of Distrobox need to be present! Please look up how to install it your distribution.\nhttps://distrobox.it/#installation\n"
        exit 1
    fi 
}

check_install_fun() { # Function for checking if Flashpoint is installed.
    local YN

    # If the state isn't "install" then do a quick check.
    if [ "$STATE" != "install" ]; then

        # If no Flashpoint installation was detected then tell the user and exit.
        if ! grep -q "Flashpoint" "$HOME/.flashpoint/fp-dt/version.txt" 2>/dev/null; then
            printf "Flashpoint isn't installed!\n"
            exit 1
        fi

    else

        # If "$HOME/.flashpoint" exists the continue.
        if [ -d "$HOME/.flashpoint" ]; then

            # Check if Flashpoint is installed.
            if grep -q "Flashpoint" "$HOME/.flashpoint/fp-dt/version.txt" 2>/dev/null; then
                printf "Flashpoint is already installed!\n"
                exit 2
        
            else
                # If Flashpoint wasn't installed but "$HOME/.flashpoint" existed then ask the user if they want to delete the directory.
                printf "'$HOME/.flashpoint' already exists, but no Flashpoint installation was detected! Would you like to delete everything in this directory?\nThis is asked because '$HOME/.flashpoint' might contain important data.\n"
                read -rp "[Y/n] " YN

                # If user says yes then delete and remake the directory.
                if [[ "$YN" =~ ^([Yy]|[Yy][Ee][Ss])$ ]]; then
                     rm -rf "$HOME/.flashpoint"
                     mkdir -p "$HOME/.flashpoint"

                # If user says no then exit.
                elif [[ "$YN" =~ ^([Nn]|[Nn][Oo])$ ]]; then
                    printf "A fresh '$HOME/.flashpoint' is needed for installing Flashpoint, exiting..\n"
                    exit 1

                # Exit if yes or no weren't said.
                else
                    printf "Unknown option, exiting..\n"
                    exit 2
                fi    

            fi    

        # If "$HOME/.flashpoint" doesn't exist then make the directory and finish.
        else
            mkdir -p "$HOME/.flashpoint"
        fi

    fi    
}

check_distrobox_fun() {
    if distrobox list | grep -q '\<Flashpoint\>' 2>/dev/null; then
        printf "The Distrobox container already exists.\n"
        exit 1
    fi
}

