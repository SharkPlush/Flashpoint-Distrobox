#!/bin/bash



update_fp_fun() { # The current updater has an issue that if the user hasnt launcher FP yet but decides to update it for some reason it'll have issues.
		checks_fun
    
    # Has the user enter the location of the Flashpoint zip and does magic things
    read -e -p "Enter the location of the Flashpoint .7z file: " filepath; filepath="${filepath/#\~/$HOME}"
    
    if [ ! -f "$filepath" ]; then
        echo "File does not exist"; exit 1
        
    elif [[ "$filepath" = *.7z ]]; then
        mkdir -p "$HOME/.flashpoint/.update-folder-temp-dont-delete-2"
        distrobox-enter Flashpoint -T -- bash -c '7za x "$1" -o"$HOME/.update-folder-temp-dont-delete-2"' bash "$filepath" > /dev/null 2>&1
        
        if ! grep -q "Flashpoint" "$HOME/.flashpoint/.update-folder-temp-dont-delete-2/version.txt" 2>/dev/null; then
            echo "The extracted .7z file wasn't Flashpoint!"; rm -rf "$HOME/.flashpoint/.update-folder-temp-dont-delete-2"
            distrobox-stop Flashpoint --yes > /dev/null 2>&1; exit 1 
        fi
        
    else
        echo "The file must be a .7z archive!"; rm -rf "$HOME/.flashpoint/.update-folder-temp-dont-delete-2"
        distrobox-stop Flashpoint --yes > /dev/null 2>&1; exit 1 
    fi
    # Has the user enter the location of the Flashpoint zip and does magic things  
        
    # Detects if Flashpoint actually needs to updates (or downgrade i guess)
    if [ "$(cat "$HOME/.flashpoint/.update-folder-temp-dont-delete-2/version.txt")" = "$(cat "$HOME/.flashpoint/fp-dt/version.txt")" ]; then
        echo "Flashpoint is already up-to-date."; rm -rf "$HOME/.flashpoint/.update-folder-temp-dont-delete-2"; exit 0
    fi
    # Detects if Flashpoint actually needs to updates (or downgrade i guess)
        
    # If Flashpoint needs an update then give the user a warning of what might happen and a choice to cancel
    echo "Flashpoint is outdated! This manager tries to preserve as much data as possible but.."
    echo "Some data like custom playlists might be lost! If you want you can find them in"
    echo "'$HOME/.flashpoint/fp-dt/Data/Playlists/' and copy paste them back in after the update is finished."
    echo "Would you like to update?"
    read -rp "[Y/n] " Yn
    # If Flashpoint needs an update then give the user a warning of what might happen and a choice to cancel
        
    # The whole update process
    if [[ "$Yn" =~ ^([Yy]|[Yy][Ee][Ss])$ ]]; then
        echo "Starting update.."
        mkdir -p "$HOME/.flashpoint/.update-folder-temp-dont-delete"
       
        # FILE MANAGEMENT BS FOR DATA PRESERVATION
        cp "$HOME/.flashpoint/fp-dt/preferences.json"              "$HOME/.flashpoint/.update-folder-temp-dont-delete"
        cp "$HOME/.flashpoint/fp-dt/Data/Playlists/Favorites.json" "$HOME/.flashpoint/.update-folder-temp-dont-delete"
        cp "$HOME/.flashpoint/fp-dt/Data/flashpoint.sqlite"        "$HOME/.flashpoint/.update-folder-temp-dont-delete"
        cp -r "$HOME/.flashpoint/fp-dt/Data/Games"                 "$HOME/.flashpoint/.update-folder-temp-dont-delete"
        cp -r "$HOME/.flashpoint/fp-dt/Legacy/htdocs"              "$HOME/.flashpoint/.update-folder-temp-dont-delete"
        cp -r "$HOME/.flashpoint/fp-dt/FPSoftware/Wine"            "$HOME/.flashpoint/.update-folder-temp-dont-delete"

        rm -rf "$HOME/.flashpoint/fp-dt/"; mv "$HOME/.flashpoint/.update-folder-temp-dont-delete-2" "$HOME/.flashpoint/fp-dt"
            
        rm -f  "$HOME/.flashpoint/fp-dt/preferences.json"
        rm -f  "$HOME/.flashpoint/fp-dt/Data/Playlists/Favorites.json"
        rm -f  "$HOME/.flashpoint/fp-dt/Data/flashpoint.sqlite"
        rm -rf "$HOME/.flashpoint/fp-dt/Data/Games"
        rm -rf "$HOME/.flashpoint/fp-dt/Legacy/htdocs"
        rm -rf "$HOME/.flashpoint/fp-dt/FPSoftware/Libraries"
        rm -rf "$HOME/.flashpoint/fp-dt/FPSoftware/Wine"  
        
        cp "$HOME/.flashpoint/.update-folder-temp-dont-delete/preferences.json"  "$HOME/.flashpoint/fp-dt"
        cp "$HOME/.flashpoint/.update-folder-temp-dont-delete/Favorites.json"    "$HOME/.flashpoint/fp-dt/Data/Playlists/"
        cp "$HOME/.flashpoint/.update-folder-temp-dont-delete/flashpoint.sqlite" "$HOME/.flashpoint/fp-dt/Data/"
        cp -r "$HOME/.flashpoint/.update-folder-temp-dont-delete/Games"          "$HOME/.flashpoint/fp-dt/Data/"
        cp -r "$HOME/.flashpoint/.update-folder-temp-dont-delete/htdocs"         "$HOME/.flashpoint/fp-dt/Legacy/"
        cp -r "$HOME/.flashpoint/.update-folder-temp-dont-delete/Wine"           "$HOME/.flashpoint/fp-dt/FPSoftware/"
        # FILE MANAGEMENT BS FOR DATA PRESERVATION

        rm -rf "$HOME/.flashpoint/.update-folder-temp-dont-delete"
        distrobox-stop Flashpoint --yes > /dev/null 2>&1; echo "Flashpoint has been updated."; exit 0
    # The whole update process
        
    # If the user doesnt wanna update just cancel and delete the junk
    elif [[ "$Yn" =~ ^([Nn]|[Nn][Oo])$ ]]; then
        echo "Ok we won't update!"; rm -rf "$HOME/.flashpoint/.update-folder-temp-dont-delete-2"
        distrobox-stop Flashpoint --yes > /dev/null 2>&1; exit 0
            
    else
        echo "Unknown option, exiting.."; rm -rf "$HOME/.flashpoint/.update-folder-temp-dont-delete-2"
        distrobox-stop Flashpoint --yes > /dev/null 2>&1; exit 1
        
    fi
    # If the user doesnt wanna update just cancel and delete the junk
}



distrobox_setup_fun() {
    checks_fun

    echo "Distrobox will install a Fedora 40 image with the dependencies for Flashpoint. (This will take a while)"
    
    # Creates the Distrobox container
    distrobox-create \
    --no-entry \
    --image fedora:40 \
    --home "$HOME/.flashpoint/" \
    --name Flashpoint \
    --yes > /dev/null 2>&1       
    # Creates the Distrobox container    
    
    # Installs Flashpoints dependencies inside the Distrobox container
    distrobox-enter Flashpoint -T -- bash -c 'sudo dnf install \
                                              xorg-x11-server-Xwayland \
                                              gtk3 \
                                              nss \
                                              pipewire-pulseaudio \
                                              php \
                                              p7zip \
                                              wine \
                                              libXcomposite.i686 \
                                              pulseaudio-libs.i686 \
                                              gtk2 \
                                              libXt -y \
                                             ' > /dev/null 2>&1
    # Installs Flashpoints dependencies inside the Distrobox container
                                      
    # Has the user enter the location of the Flashpoint zip and does magic things
    read -e -p "Enter the location of the Flashpoint .7z file: " filepath; filepath="${filepath/#\~/$HOME}"
    
    if [ ! -f "$filepath" ]; then
        echo "File does not exist"; exit 1
    
    elif [[ "$filepath" = *.7z ]]; then
        mkdir -p "$HOME/.flashpoint/fp-dt/"
        distrobox-enter Flashpoint -T -- bash -c '7za x "$1" -o"$HOME/fp-dt"' bash "$filepath" > /dev/null 2>&1
        
        if ! grep -q "Flashpoint" "$HOME/.flashpoint/fp-dt/version.txt" 2>/dev/null; then
            echo "The extracted .7z file wasn't Flashpoint!"; rm -rf "$HOME/.flashpoint/fp-dt"
            distrobox-stop Flashpoint --yes > /dev/null 2>&1; exit 1
        
        else
            rm -rf "$HOME/.flashpoint/fp-dt/FPSoftware/Libraries"; rm -rf "$HOME/.flashpoint/fp-dt/FPSoftware/Wine"
            mkdir -p "$HOME/.flashpoint/fp-dt/FPSoftware/Wine"
            distrobox-enter Flashpoint -T -- bash -c 'WINEPREFIX="$HOME/fp-dt/FPSoftware/Wine" wineboot' > /dev/null 2>&1
        fi
    
    else
        echo "The file must be a .7z archive"; rm -rf "$HOME/.flashpoint/fp-dt"
        distrobox-stop Flashpoint --yes > /dev/null 2>&1; exit 1  
    fi
    # Has the user enter the location of the Flashpoint zip and does magic things    

    distrobox-stop Flashpoint --yes > /dev/null 2>&1
    create_desktop_entry_fun
}



delete_fun () {
    checks_fun
    
    if [ "$STATE" = "delete" ]; then
    
        # make sure the user will know what will happen
        echo "This will delete Flashpoint with its data and delete the Distrobox container! Are you sure you want to do this?"
        read -rp "[Y/n] " Yn
        # make sure the user will know what will happen
        
        # if user wants to delete then remove everything but the fedora 40 image as they may have had it installed before this program
        if [[ "$Yn" =~ ^([Yy]|[Yy][Ee][Ss])$ ]]; then
            distrobox-rm Flashpoint --yes > /dev/null 2>&1
            rm -rf "$HOME/.flashpoint"; rm -f "$HOME/.local/bin/flashpointwrapper.sh"; rm -f "$HOME/.local/share/applications/flashpoint-archive.desktop"
            echo "Everything has been deleted except the Fedora 40 container image! You'll have to do that yourself with Docker or Podman."; exit 0
        # if user wants to delete then remove everything but the fedora 40 image as they may have had it installed before this program    
         
        # if no then no lol 
        elif [[ "$Yn" =~ ^([Nn]|[Nn][Oo])$ ]]; then
            echo "Ok we won't delete."; exit 0
            
        else
          echo "Unknown option, exiting.."; exit 1
        fi
        # if no then no lol
        
    elif [ "$STATE" = "reinstall" ]; then
    
        # make sure the user will know what will happen
        echo "This will re-install Flashpoint and the Distrobox container are you sure want to do this? (Your data will be lost)"
        read -rp "[Y/n] " Yn
        # make sure the user will know what will happen
        
        # if user wants reinstall just delete everything and run the install functions
        if [[ "$Yn" =~ ^([Yy]|[Yy][Ee][Ss])$ ]]; then
            echo "Starting re-install.."
            distrobox-rm Flashpoint --yes > /dev/null 2>&1  
            rm -rf "$HOME/.flashpoint"; rm -f "$HOME/.local/bin/flashpointwrapper.sh"; rm -f "$HOME/.local/share/applications/flashpoint-archive.desktop"
            STATE="install"; distrobox_setup_fun
        # if user wants reinstall just delete everything and run the install functions   
            
        # if no then no idk lmao    
        elif [[ "$Yn" =~ ^([Nn]|[Nn][Oo])$ ]]; then
            echo "Ok we won't re-install."; exit 0
            
        else
            echo "Unknown option, exiting.."; exit 1
        fi
        # if no then no idk lmao
    fi
}



create_desktop_entry_fun() {
    mkdir -p "$HOME/.local/bin" # make this as some user folders might not have it

# Flashpoint + Distro wrapper
    if [ -f "$HOME/.local/bin/flashpointwrapper.sh" ]; then
        rm "$HOME/.local/bin/flashpointwrapper.sh"
    fi
    cat > "$HOME/.local/bin/flashpointwrapper.sh" <<EOF
#!/bin/bash
trap "distrobox-stop Flashpoint --yes" EXIT
distrobox-enter Flashpoint -T -- bash -c '/usr/bin/env -S WINEPREFIX="$HOME/.flashpoint/fp-dt/FPSoftware/Wine" "$HOME/.flashpoint/fp-dt/Launcher/flashpoint-launcher" --js-flags=--lite_mode --ozone-platform-hint=auto'
EOF
    chmod +x "$HOME/.local/bin/flashpointwrapper.sh"
# Flashpoint + Distrobox wrapper

# Desktop entry for the wrapper
    if [ -f "$HOME/.local/share/applications/flashpoint-archive.desktop" ]; then
        rm "$HOME/.local/share/applications/flashpoint-archive.desktop"
    fi
    cat > "$HOME/.local/share/applications/flashpoint-archive.desktop" <<EOF
[Desktop Entry]
Type=Application
Name=Flashpoint Archive
Comment=An archive for games and animations from the web.
Icon=$HOME/.flashpoint/fp-dt/Launcher/icon.svg
StartupWMClass=flashpoint-launcher
Exec=$HOME/.local/bin/flashpointwrapper.sh
Path=$HOME/.flashpoint/fp-dt/Launcher
Terminal=false
Categories=Archiving;Game;
SingleMainWindow=true
EOF
# Desktop entry for the wrapper

    echo "Flashpoint has been installed."; exit 0
}



help_list_fun() { # just the help list nothing to it
    echo "Usage:"
    echo "--help                 |  Brings up the manager options."
    echo "--install-flashpoint   |  Installs Flashpoint and the Distrobox container."
    echo "--update-flashpoint    |  Updates Flashpoint."
    echo "--reinstall-flashpoint |  Re-installs Flashpoint and the Distrobox container."
    echo "--delete-flashpoint    |  Deletes Flashpoint the Distrobox container."
    echo "--enable-wine-wayland  |  Enables Wine native Wayland. (Disabled by default)"
    echo "--disable-wine-wayland |  Disables Wine native Wayland. (Disabled by default)"
    echo "--enable-audio-fix     |  Enables ALSA audio backend for Wine this can fix issue with audio. (Disabled by default)"
    echo "--disable-audio-fix    |  Disables the ALSA audio backend in favor of PulseAudio. (Disabled by default)"
    exit 0
}



ad_fx_fun() {
    checks_fun
    
    if [ "$STATE" = "ad_fx_di" ]; then
    
        # check if audio fix is already disabled
        if [ "$(grep '"Audio"' "$HOME/.flashpoint/fp-dt/FPSoftware/Wine/user.reg" 2>/dev/null)" = '"Audio"="pulse"' ] || [ -z "$(grep '"Audio"' "$HOME/.flashpoint/fp-dt/FPSoftware/Wine/user.reg" 2>/dev/null)" ]; then
            echo "Audio fix is already disabled"; exit 0
        # check if audio fix is already disabled
            
        # if audio fix is enabled then disable
        else
        
            # user might try to edit wine settings while fp is open this is bad so we close everything first
            if pgrep -f flashpoint-archive > /dev/null 2>&1; then
            
                echo "To change Wine settings Flashpoint must be closed! Would you like to close it now?"
                read -rp "[Y/n] " Yn
                
                if [[ "$Yn" =~ ^([Yy]|[Yy][Ee][Ss])$ ]]; then
                    pkill -SIGTERM -f flashpoint-archive; sleep 5
                    distrobox-enter Flashpoint -T -- bash -c 'WINEPREFIX="$HOME/fp-dt/FPSoftware/Wine" wine reg add "HKCU\Software\Wine\Drivers" /v Audio /d pulse /f' > /dev/null 2>&1
                    distrobox-stop Flashpoint --yes > /dev/null 2>&1
                    echo "Audio fix disabled."; exit 0
                    
                elif [[ "$Yn" =~ ^([Nn]|[Nn][Oo])$ ]]; then
                    echo "Ok we won't close Flashpoint."; exit 0
                    
                else
                    echo "Unknown option, exiting.."; exit 1
                fi
            # user might try to edit wine settings while fp is open this is bad so we close everything first
        
            # if the dt container is off then just do the setting like normal
            else
                distrobox-enter Flashpoint -T -- bash -c 'WINEPREFIX="$HOME/fp-dt/FPSoftware/Wine" wine reg add "HKCU\Software\Wine\Drivers" /v Audio /d pulse /f' > /dev/null 2>&1
                distrobox-stop Flashpoint --yes > /dev/null 2>&1
                echo "Audio fix disabled."; exit 0
            fi
            # if the dt container is off then just do the setting like normal
        
        fi      
        # if audio fix is enabled then disable

    elif [ "$STATE" = "ad_fx_en" ]; then
    
        # if the audio fix is already enabled then just exit
        if [ "$(grep '"Audio"' "$HOME/.flashpoint/fp-dt/FPSoftware/Wine/user.reg" 2>/dev/null)" = '"Audio"="alsa"' ]; then
            echo "Audio fix is already enabled."; exit 0    
        # if the audio fix is already enabled then just exit
      
        # if audio fix not enabled then enable
        else
          
            # user might try to edit wine settings while fp is open this is bad so we close everything first
            if pgrep -f flashpoint-archive > /dev/null 2>&1; then
          
                echo "To change Wine settings Flashpoint must be closed! Would you like to close it now?"
                read -rp "[Y/n] " Yn
          
                if [[ "$Yn" =~ ^([Yy]|[Yy][Ee][Ss])$ ]]; then
                    pkill -SIGTERM -f flashpoint-archive; sleep 5
                    distrobox-enter Flashpoint -T -- bash -c 'WINEPREFIX="$HOME/fp-dt/FPSoftware/Wine" wine reg add "HKCU\Software\Wine\Drivers" /v Audio /d alsa /f' > /dev/null 2>&1
                    distrobox-stop Flashpoint --yes > /dev/null 2>&1
                    echo "Audio fix enabled."; exit 0
              
                elif [[ "$Yn" =~ ^([Nn]|[Nn][Oo])$ ]]; then
                    echo "Ok we won't close Flashpoint."; exit 0
                    
                else
                    echo "Unknown option, exiting.."; exit 1
                fi
            # user might try to edit wine settings while fp is open this is bad so we close everything first
               
            # if the dt container is off then just do the setting like normal
            else
                distrobox-enter Flashpoint -T -- bash -c 'WINEPREFIX="$HOME/fp-dt/FPSoftware/Wine" wine reg add "HKCU\Software\Wine\Drivers" /v Audio /d alsa /f' > /dev/null 2>&1
                distrobox-stop Flashpoint --yes > /dev/null 2>&1
                echo "Audio fix enabled."; exit 0
            fi  
            # if the dt container is off then just do the setting like normal
      
        fi
        # if audio fix not enabled then enable
    
    fi
}



