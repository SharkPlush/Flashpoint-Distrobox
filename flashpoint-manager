#!/bin/bash

update_fp_fun() { # This function updates (or downgrades) Flashpoint and tries it's best to preserve data.

# The update proccess kinda sucks because it is complicated, but whatever it works and IMO it is the best way of updating.
# The update works by taking a new .7z Flashpoint file and cross checking the "version.txt" file inside it with the currently installed one.
# This allows for downgrades to but this isn't made for that.
# If an update is needed then the simple way of explaining it is the user data from their current install is copied to a temporary directory.
# Then the users whole Flashpoint install gets deleted and replaced with the new version that was extracted.
# After that the user data gets put back where it needs to be and some clean ups happen thats it.

    local twofilepath fiveYn
    
    # Has the user enter the location of the Flashpoint zip and does magic things
    read -e -p "Enter the location of the Flashpoint .7z file: " twofilepath
    twofilepath="${twofilepath/#\~/$HOME}"
    
    # If file path doesn't exist then exit.
    if [ ! -f "$twofilepath" ]; then
        printf "File does not exist\n"
        exit 1
    fi
    
    # If file wasn't a .7z then exit.
    if [[ "$twofilepath" != *.7z ]]; then
        printf "The file must be a .7z archive!"
        rm -rf "$HOME/.flashpoint/.update-folder-temp-dont-delete-2"
        distrobox-stop Flashpoint --yes > /dev/null 2>&1
        exit 2 
    fi

    # This can only be reached if the provided file was a .7z
    # Make a temporary directory to hold the extracted contents.
    mkdir -p "$HOME/.flashpoint/.update-folder-temp-dont-delete-2"
    distrobox-enter Flashpoint -T -- bash -c '7za x "$1" -o"$HOME/.update-folder-temp-dont-delete-2"' bash "$twofilepath" > /dev/null 2>&1
   
    # If the extracted .7z file wasn't Flashpoint then delete the extracted contents and exit.     
    if ! grep -q "Flashpoint" "$HOME/.flashpoint/.update-folder-temp-dont-delete-2/version.txt" 2>/dev/null; then
        printf "The extracted .7z file wasn't Flashpoint!\n"
        rm -rf "$HOME/.flashpoint/.update-folder-temp-dont-delete-2"
        distrobox-stop Flashpoint --yes > /dev/null 2>&1
        exit 1 
    fi

    # Detects if Flashpoint actually needs to updates. (or downgrade I guess?)
    if [ "$(cat "$HOME/.flashpoint/.update-folder-temp-dont-delete-2/version.txt")" = "$(cat "$HOME/.flashpoint/fp-dt/version.txt")" ]; then
        printf "Flashpoint is already up-to-date.\n"
        rm -rf "$HOME/.flashpoint/.update-folder-temp-dont-delete-2"
        exit 0
    fi
        
    # If Flashpoint needs an update then give the user a warning of what might happen and a choice to cancel
    printf "Flashpoint is outdated! This manager tries to preserve as much data as possible but..\nSome data like custom playlists might be lost! If you want you can find them in\n'$HOME/.flashpoint/fp-dt/Data/Playlists/' and copy paste them back in after the update is finished.\nWould you like to update?\n"
    read -rp "[Y/n] " fiveYn

    # If user says yes then continue.
    if [[ "$fiveYn" =~ ^([Yy]|[Yy][Ee][Ss])$ ]]; then
        printf "Starting update..\n"
        
    # If user says no then just cleanup and exit.
    elif [[ "$fiveYn" =~ ^([Nn]|[Nn][Oo])$ ]]; then
        printf "Ok we won't update!\n"
        rm -rf "$HOME/.flashpoint/.update-folder-temp-dont-delete-2"
        distrobox-stop Flashpoint --yes > /dev/null 2>&1
        exit 0
            
    # If yes or no wasn't said then just cleanup and exit.
    else
        printf "Unknown option, exiting..\n"
        rm -rf "$HOME/.flashpoint/.update-folder-temp-dont-delete-2"
        distrobox-stop Flashpoint --yes > /dev/null 2>&1
        exit 2
        
    fi
    
    # This can only be reached if user said yes.
    # Make a temporary directory to store user data.
    mkdir -p "$HOME/.flashpoint/.update-folder-temp-dont-delete"
       
    # Everything here transfers user data to a temporary directory.
    if [ -f "$HOME/.flashpoint/fp-dt/preferences.json" ]; then
        cp "$HOME/.flashpoint/fp-dt/preferences.json" "$HOME/.flashpoint/.update-folder-temp-dont-delete"
    fi

    if [ -f "$HOME/.flashpoint/fp-dt/Data/Playlists/Favorites.json" ]; then
        cp "$HOME/.flashpoint/fp-dt/Data/Playlists/Favorites.json" "$HOME/.flashpoint/.update-folder-temp-dont-delete"
    fi

    if [ -f "$HOME/.flashpoint/fp-dt/Data/flashpoint.sqlite" ]; then
       cp "$HOME/.flashpoint/fp-dt/Data/flashpoint.sqlite" "$HOME/.flashpoint/.update-folder-temp-dont-delete"
    fi

    if [ -d "$HOME/.flashpoint/fp-dt/Data/Games" ]; then
        cp -r "$HOME/.flashpoint/fp-dt/Data/Games" "$HOME/.flashpoint/.update-folder-temp-dont-delete"
    else
        printf "'$HOME/.flashpoint/fp-dt/Data/Games' doesn't exist.\n"
    fi

    if [ -d "$HOME/.flashpoint/fp-dt/Legacy/htdocs" ]; then
        cp -r "$HOME/.flashpoint/fp-dt/Legacy/htdocs" "$HOME/.flashpoint/.update-folder-temp-dont-delete"
    fi

    if [ -d "$HOME/.flashpoint/fp-dt/FPSoftware/Wine" ]; then
        cp -r "$HOME/.flashpoint/fp-dt/FPSoftware/Wine" "$HOME/.flashpoint/.update-folder-temp-dont-delete"
    fi

    # After all user data is preserved delete the old Flashpoint install and replace it with the new one.
    rm -rf "$HOME/.flashpoint/fp-dt/"
    mv "$HOME/.flashpoint/.update-folder-temp-dont-delete-2" "$HOME/.flashpoint/fp-dt"
            
    # Remove all the conflicting stuff from the new "fp-dt" directory.
    if [ -f "$HOME/.flashpoint/.update-folder-temp-dont-delete/preferences.json" ]; then
        rm -f "$HOME/.flashpoint/fp-dt/preferences.json"
    fi

    if [ -f "$HOME/.flashpoint/.update-folder-temp-dont-delete/Favorites.json" ]; then
        rm -f "$HOME/.flashpoint/fp-dt/Data/Playlists/Favorites.json"
    fi

    if [ -f "$HOME/.flashpoint/.update-folder-temp-dont-delete/flashpoint.sqlite" ]; then
        rm -f "$HOME/.flashpoint/fp-dt/Data/flashpoint.sqlite"
    fi

    if [ -d "$HOME/.flashpoint/.update-folder-temp-dont-delete/flashpoint.sqlite/Games" ]; then
        rm -rf "$HOME/.flashpoint/fp-dt/Data/Games"
    fi

    if [ -d "$HOME/.flashpoint/.update-folder-temp-dont-delete/htdocs" ]; then 
        rm -rf "$HOME/.flashpoint/fp-dt/Legacy/htdocs"
    fi

    # These two need to be removed no matter what.
    rm -rf "$HOME/.flashpoint/fp-dt/Libraries"
    rm -rf "$HOME/.flashpoint/fp-dt/FPSoftware/Wine"  
       
    # Move all the user data back to where it should be.
    if [ -f "$HOME/.flashpoint/.update-folder-temp-dont-delete/preferences.json" ]; then 
        cp "$HOME/.flashpoint/.update-folder-temp-dont-delete/preferences.json" "$HOME/.flashpoint/fp-dt"
    fi

    if [ -f "$HOME/.flashpoint/.update-folder-temp-dont-delete/Favorites.json" ]; then
        cp "$HOME/.flashpoint/.update-folder-temp-dont-delete/Favorites.json" "$HOME/.flashpoint/fp-dt/Data/Playlists/"
    fi

    if [ -f "$HOME/.flashpoint/.update-folder-temp-dont-delete/flashpoint.sqlite" ]; then
        cp "$HOME/.flashpoint/.update-folder-temp-dont-delete/flashpoint.sqlite" "$HOME/.flashpoint/fp-dt/Data/"
    fi

    if [ -d "$HOME/.flashpoint/.update-folder-temp-dont-delete/Games" ]; then
        cp -r "$HOME/.flashpoint/.update-folder-temp-dont-delete/Games" "$HOME/.flashpoint/fp-dt/Data/"
    fi

    if [ -d "$HOME/.flashpoint/.update-folder-temp-dont-delete/htdocs" ]; then
        cp -r "$HOME/.flashpoint/.update-folder-temp-dont-delete/htdocs" "$HOME/.flashpoint/fp-dt/Legacy/"
    fi

    if [ -d "$HOME/.flashpoint/.update-folder-temp-dont-delete/Wine" ]; then
        cp -r "$HOME/.flashpoint/.update-folder-temp-dont-delete/Wine" "$HOME/.flashpoint/fp-dt/FPSoftware/"
    fi

    # Cleanup.
    rm -rf "$HOME/.flashpoint/.update-folder-temp-dont-delete"
    distrobox-stop Flashpoint --yes > /dev/null 2>&1
    printf "Flashpoint has been updated.\n"
    exit 0
}

create_desktop_entry_fun() { # This function creates a wrapper and desktop entry after the main install finishes.
    # We make this as some people might not have it by default.
    mkdir -p "$HOME/.local/bin"

    # We make sure to delete any potential leftovers if user is reinstalling.
    if [ -f "$HOME/.local/bin/flashpointwrapper.sh" ]; then
        rm "$HOME/.local/bin/flashpointwrapper.sh"
    fi

    if [ -f "$HOME/.local/share/applications/flashpoint-archive.desktop" ]; then
        rm "$HOME/.local/share/applications/flashpoint-archive.desktop"
    fi

    # This is a wrapper for Distrobox + Flashpoint that will make Distrobox exit properly when Flashpoint closes.
    cat > "$HOME/.local/bin/flashpointwrapper.sh" <<EOF && chmod +x "$HOME/.local/bin/flashpointwrapper.sh"
#!/bin/bash
trap "distrobox-stop Flashpoint --yes" EXIT
distrobox-enter Flashpoint -T -- bash -c '/usr/bin/env -S WINEPREFIX="$HOME/.flashpoint/fp-dt/FPSoftware/Wine" "$HOME/.flashpoint/fp-dt/Launcher/flashpoint-launcher" --js-flags=--lite_mode --ozone-platform-hint=auto'
EOF

    # A .desktop entry for the wrapper above.
    cat > "$HOME/.local/share/applications/flashpoint-archive.desktop" <<EOF
[Desktop Entry]
Type=Application
Name=Flashpoint Archive
Comment=An archive for games and animations from the web.
Icon=$HOME/.flashpoint/fp-dt/Launcher/icon.svg
StartupWMClass=flashpoint-launcher
Exec=$HOME/.local/bin/flashpointwrapper.sh
Path=$HOME/.flashpoint/fp-dt/Launcher
Terminal=false
Categories=Archiving;Game;
SingleMainWindow=true
EOF

    printf "Flashpoint has been installed.\n"
    exit 0
}

distrobox_setup_fun() { # This function is for setting up the Distrobox container and installing Flashpoint.
    local onefilepath

    printf "Distrobox will install a Fedora 40 image with the dependencies for Flashpoint. (This will take a while)\n"
    
    # Creates the Distrobox container.
    distrobox-create \
    --no-entry \
    --image fedora:40 \
    --home "$HOME/.flashpoint/" \
    --name Flashpoint \
    --yes > /dev/null 2>&1       

    # Installs Flashpoints dependencies inside the Distrobox container
    distrobox-enter Flashpoint -T -- bash -c 'sudo dnf install \
                                              xorg-x11-server-Xwayland \
                                              gtk3 \
                                              nss \
                                              pipewire-pulseaudio \
                                              php \
                                              p7zip \
                                              wine \
                                              libXcomposite.i686 \
                                              pulseaudio-libs.i686 \
                                              gtk2 \
                                              libXt -y \
                                             ' > /dev/null 2>&1
                                      
    # Has the user enter the location of the Flashpoint zip and does magic things
    read -e -p "Enter the location of the Flashpoint .7z file: " onefilepath
    onefilepath="${onefilepath/#\~/$HOME}"
    
    # If file path doesn't exist then exit.
    if [ ! -f "$onefilepath" ]; then
        printf "File does not exist\n"
        exit 1
    fi

    # If file wasn't a .7z then exit.
    if [[ "$onefilepath" != *.7z ]]; then
        printf "The file must be a .7z archive\n"
        rm -rf "$HOME/.flashpoint/fp-dt"
        distrobox-stop Flashpoint --yes > /dev/null 2>&1
        exit 2
    fi

    # This can only be reached if the provided file was a .7z
    printf "Extracting the zip file..\n"
    distrobox-enter Flashpoint -T -- bash -c '7za x "$1" -o"$HOME/fp-dt"' bash "$onefilepath" > /dev/null 2>&1
    
    # If the extracted .7z file wasn't Flashpoint then delete the extracted contents and exit.
    if ! grep -q "Flashpoint" "$HOME/.flashpoint/fp-dt/version.txt" 2>/dev/null; then
        printf "The extracted .7z file wasn't Flashpoint!\n"
        rm -rf "$HOME/.flashpoint/fp-dt"
        distrobox-stop Flashpoint --yes > /dev/null 2>&1
        exit 1
        
    # If everything went like it should delete unneeded extras and continue.
    else
        rm -rf "$HOME/.flashpoint/fp-dt/Libraries"
        rm -rf "$HOME/.flashpoint/fp-dt/FPSoftware/Wine"
        mkdir -p "$HOME/.flashpoint/fp-dt/FPSoftware/Wine"
        distrobox-enter Flashpoint -T -- bash -c 'WINEPREFIX="$HOME/fp-dt/FPSoftware/Wine" wineboot' > /dev/null 2>&1
    fi

    distrobox-stop Flashpoint --yes > /dev/null 2>&1
    create_desktop_entry_fun
}

delete_fun () { # This function is for deleting Flashpoint + Distrobox container.
    local fourYn
    
    if [ "$STATE" = "delete" ]; then
        printf "This will delete Flashpoint with its data and also delete the Distrobox container! Are you sure you want to do this?\n"
        read -rp "[Y/n] " fourYn

        # If users says yes then continue.
        if [[ "$fourYn" =~ ^([Yy]|[Yy][Ee][Ss])$ ]]; then
            printf "Deletion is starting\n"
         
        # If user says no then exit.
        elif [[ "$fourYn" =~ ^([Nn]|[Nn][Oo])$ ]]; then
            printf "Ok we won't delete.\n"
            exit 0
          
        # If yes or no wasn't said just exit.  
        else
          printf "Unknown option, exiting..\n"
          exit 2
        fi
        
        # The user could've deleted Distrobox on their own so we sure it's installed before trying to delete anything.
        # We delete everything but the fedora:40 image has user maybe had that installed before this script.
        if command -v distrobox > /dev/null 2>&1; then
            distrobox-rm Flashpoint --yes > /dev/null 2>&1
        else
            printf "You deleted Distrobox so flashpoint-manager can't check if the 'Flashpoint' Distrobox container exists.\n"
        fi

        rm -rf "$HOME/.flashpoint"
        rm -f "$HOME/.local/bin/flashpointwrapper.sh"
        rm -f "$HOME/.local/share/applications/flashpoint-archive.desktop"
        printf "Everything has been deleted except the Fedora 40 container image! You'll have to do that yourself with Docker or Podman.\n"
        exit 0

    fi

    if [ "$STATE" = "reinstall" ]; then
        printf "This will re-install Flashpoint and the Distrobox container are you sure want to do this? (Your saved data will be lost)\n"
        read -rp "[Y/n] " fourYn
        
        # If user says yes then continue.
        if [[ "$fourYn" =~ ^([Yy]|[Yy][Ee][Ss])$ ]]; then
            printf "Starting re-install..\n"

        # if user says no then exit.   
        elif [[ "$fourYn" =~ ^([Nn]|[Nn][Oo])$ ]]; then
            printf "Ok we won't re-install.\n"
            exit 0
            
        # If yes or no wasn't said then exit.
        else
            echo "Unknown option, exiting.."
            exit 2
        fi

        # Delete everything and run the install function.
        distrobox-rm Flashpoint --yes > /dev/null 2>&1  
        rm -rf "$HOME/.flashpoint"
        rm -f "$HOME/.local/bin/flashpointwrapper.sh"
        rm -f "$HOME/.local/share/applications/flashpoint-archive.desktop"
        distrobox_setup_fun

    fi
}

ad_fx_fun() { # This function enables / disables the audio fixes WINE might need.
    local threeYn
    
    if [ "$STATE" = "ad_fx_di" ]; then
    
        # If audio fix is already disabled then exit.
        if [ "$(grep '"Audio"' "$HOME/.flashpoint/fp-dt/FPSoftware/Wine/user.reg" 2>/dev/null)" = '"Audio"="pulse"' ] || [ -z "$(grep '"Audio"' "$HOME/.flashpoint/fp-dt/FPSoftware/Wine/user.reg" 2>/dev/null)" ]; then
            printf "Audio fix is already disabled\n"
            exit 2
        fi

        # If audio fix is enabled then continue.

        # If Flashpoint is open then we need to close it.
        if pgrep -f flashpoint-archive > /dev/null 2>&1; then
            
            # Asking to close it is probably the best approach as user might be playing a game and have unsaved data.
            printf "To change Wine settings Flashpoint must be closed! Would you like to close it now?\n"
            read -rp "[Y/n] " threeYn
                
            # If user says yes then exit Flashpoint.
            if [[ "$threeYn" =~ ^([Yy]|[Yy][Ee][Ss])$ ]]; then
                pkill -SIGTERM -f flashpoint-archive
                sleep 5
                    
            # If user says no then just exit the script.
            elif [[ "$threeYn" =~ ^([Nn]|[Nn][Oo])$ ]]; then
                printf "Ok we won't close Flashpoint.\n"
                exit 0
            
            # If yes or no weren't said just exit.
            else
                printf "Unknown option, exiting..\n"
                exit 2
            fi

            # This can only be reached if yes was said.
            distrobox-enter Flashpoint -T -- bash -c 'WINEPREFIX="$HOME/fp-dt/FPSoftware/Wine" wine reg add "HKCU\Software\Wine\Drivers" /v Audio /d pulse /f' > /dev/null 2>&1
            distrobox-stop Flashpoint --yes > /dev/null 2>&1
            printf "Audio fix disabled.\n"
            exit 0
        
        # If Flashpoint isn't open then just continue like normal.
        else
            distrobox-enter Flashpoint -T -- bash -c 'WINEPREFIX="$HOME/fp-dt/FPSoftware/Wine" wine reg add "HKCU\Software\Wine\Drivers" /v Audio /d pulse /f' > /dev/null 2>&1
            distrobox-stop Flashpoint --yes > /dev/null 2>&1
            printf "Audio fix disabled.\n"
            exit 0
        fi

    fi      

    if [ "$STATE" = "ad_fx_en" ]; then
    
        # If audio fix is already enabled then exit.
        if [ "$(grep '"Audio"' "$HOME/.flashpoint/fp-dt/FPSoftware/Wine/user.reg" 2>/dev/null)" = '"Audio"="alsa"' ]; then
            printf "Audio fix is already enabled.\n"
            exit 2
        fi

        # If audio fix is disabled then continue.

        # If Flashpoint is open then we need to close it.
        if pgrep -f flashpoint-archive > /dev/null 2>&1; then
          
            # Asking to close it is probably the best approach as user might be playing a game and have unsaved data.
            printf "To change Wine settings Flashpoint must be closed! Would you like to close it now?\n"
            read -rp "[Y/n] " threeYn
          
            # If user says yes then exit Flashpoint.
            if [[ "$threeYn" =~ ^([Yy]|[Yy][Ee][Ss])$ ]]; then
                pkill -SIGTERM -f flashpoint-archive
                sleep 5
              
            # If user says no then just exit the script.
            elif [[ "$threeYn" =~ ^([Nn]|[Nn][Oo])$ ]]; then
                printf "Ok we won't close Flashpoint.\n"
                exit 0
                    
            # If yes or no weren't said just exit.
            else
                printf "Unknown option, exiting..\n"
                exit 2
            fi               
            
            # This can only be reached if yes was said.
            distrobox-enter Flashpoint -T -- bash -c 'WINEPREFIX="$HOME/fp-dt/FPSoftware/Wine" wine reg add "HKCU\Software\Wine\Drivers" /v Audio /d alsa /f' > /dev/null 2>&1
            distrobox-stop Flashpoint --yes > /dev/null 2>&1
            printf "Audio fix enabled.\n"
            exit 0

        # If Flashpoint isn't open then just continue like normal.
        else
            distrobox-enter Flashpoint -T -- bash -c 'WINEPREFIX="$HOME/fp-dt/FPSoftware/Wine" wine reg add "HKCU\Software\Wine\Drivers" /v Audio /d alsa /f' > /dev/null 2>&1
            distrobox-stop Flashpoint --yes > /dev/null 2>&1
            printf "Audio fix enabled.\n"
            exit 0
        fi        
    
    fi
}

