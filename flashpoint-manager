checks_fun() {
    # first check for dt
    if ! command -v distrobox > /dev/null 2>&1; then
        echo "An installation of Distrobox need to be present! Please look up how to install it your distribution."
        echo "https://distrobox.it/#installation"; exit 1
    fi 
    # first check for dt
    
    # if installing then checking the installation works differently
    if [ "$STATE" = "install" ]; then
        if [ -d "$HOME/.flashpoint" ]; then
            if ! grep -q "Flashpoint" "$HOME/.flashpoint/fp-dt/version.txt" 2>/dev/null; then
                echo "'$HOME/.flashpoint' exists, but no Flashpoint installation was detected! Would you like to delete everything in this directory?"
            
                # if yes delete then delete
                read -rp "[Y/n] " Yn
                
                if [[ "$Yn" =~ ^([Yy]|[Yy][Ee][Ss])$ ]]; then
                    rm -rf "$HOME/.flashpoint"; mkdir -p "$HOME/.flashpoint"
                # if yes delete then delete
            
                # if no delete dont    
                elif [[ "$Yn" =~ ^([Nn]|[Nn][Oo])$ ]]; then
                    echo "A fresh '$HOME/.flashpoint' is needed for installing Flashpoint, exiting.."; exit 1
               
                else
                    echo "Unknown option, exiting.."; exit 1
                fi
              # if no delete dont
            
            # If fp is already installed then just exit 
            else
              echo "Flashpoint is already installed!"; exit 1
            fi
            # If fp is already installed then just exit 
            
        else
            mkdir -p "$HOME/.flashpoint"
        fi 
    # if installing then checking the installation works differently     
        
    # if not installing then just check install exists
    else
    
      if ! grep -q "Flashpoint" "$HOME/.flashpoint/fp-dt/version.txt" 2>/dev/null; then
          echo "Flashpoint isn't installed!"; exit 1
      fi
    
    fi  
    # if not installing then just check install exists
}



#entry point
if [ -z "$1" ]; then STATE="help"; help_list_fun; exit 0; fi
case "$1" in
    --help) if [ $# -ne 1 ]; then
            echo "Error: --help does not accept extra arguments." >&2; exit 1; fi; STATE="help"; help_list_fun ;;
    --install-flashpoint) if [ $# -ne 1 ]; then
            echo "Error: --install-flashpoint does not accept extra arguments." >&2; exit 1; fi; STATE="install"; distrobox_setup_fun ;;
    --update-flashpoint) if [ $# -ne 1 ]; then
            echo "Error: --update-flashpoint does not accept extra arguments." >&2; exit 1; fi; STATE="update"; update_fp_fun ;;
    --reinstall-flashpoint) if [ $# -ne 1 ]; then
            echo "Error: --reinstall-flashpoint does not accept extra arguments." >&2; exit 1; fi; STATE="reinstall"; delete_fun ;;
    --delete-flashpoint) if [ $# -ne 1 ]; then
            echo "Error: --delete-flashpoint does not accept extra arguments." >&2; exit 1; fi; STATE="delete"; delete_fun ;;
    --enable-wine-wayland) if [ $# -ne 1 ]; then
            echo "Error: --enable-wine-wayland does not accept extra arguments." >&2; exit 1; fi; STATE="wn_wy_en"; win_wy_fun ;;
    --disable-wine-wayland) if [ $# -ne 1 ]; then
            echo "Error: --disable-wine-wayland does not accept extra arguments." >&2; exit 1; fi; STATE="wn_wy_di"; win_wy_fun ;;
    --enable-audio-fix) if [ $# -ne 1 ]; then
            echo "Error: --enable-audio-fix does not accept extra arguments." >&2; exit 1; fi; STATE="ad_fx_en"; ad_fx_fun ;;
    --disable-audio-fix) if [ $# -ne 1 ]; then
            echo "Error: --disable-audio-fix does not accept extra arguments." >&2; exit 1; fi; STATE="ad_fx_di"; ad_fx_fun ;;
    *) echo "Unknown Command: \"$1\"" >&2; STATE="help"; help_list_fun; exit 1 ;;
esac
